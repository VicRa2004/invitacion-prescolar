---
interface Props {
  bordeColor: string;
  iconoClass: string;
  iconoBg: string;
  titulo: string;
  detallePrincipal: string;
  detalleSecundario: string;
  bgGradient?: string;
}

const {
  bordeColor,
  iconoClass,
  iconoBg,
  titulo,
  detallePrincipal,
  detalleSecundario,
  bgGradient = "from-white/90 to-white/90",
} = Astro.props;
---

<div
  class={`bg-gradient-to-br ${bgGradient} backdrop-blur-sm p-6 rounded-2xl border-b-8 shadow-md flex items-start space-x-4 transition-transform hover:-translate-y-1 ${bordeColor}`}
>
  <div class={`p-4 rounded-xl text-2xl flex-shrink-0 ${iconoBg}`}>
    <i class={iconoClass}></i>
  </div>
  <div>
    <h3 class="text-xl font-bold text-slate-800 mb-1">
      {titulo}
    </h3>
    <p class="text-slate-600 font-medium">
      {detallePrincipal}
    </p>
    <p class="text-sm text-slate-500 mt-1">
      {detalleSecundario}
    </p>
  </div>
</div>
