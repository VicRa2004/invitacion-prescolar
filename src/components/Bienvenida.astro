---
import FotoPolaroid from "./FotoPolaroid.astro";
---

<div
  class="bg-gradient-to-br from-white/95 to-emerald-50/35 backdrop-blur-md rounded-3xl shadow-xl border-4 border-emerald-300/80 overflow-visible text-center p-6 md:p-12 relative mb-12 transform transition-all duration-300 hover:shadow-2xl"
>
  <!-- Globos interactivos en las esquinas superiores -->
  <div
    class="balloon-btn absolute -top-8 -left-3 sm:-top-12 sm:-left-6 balloon-anim pointer-events-auto"
  >
    <span
      class="emoji-span text-5xl md:text-6xl cursor-pointer select-none filter drop-shadow-md transition-transform hover:scale-110"
      >🎈</span
    >
  </div>
  <div
    class="balloon-btn absolute -top-9 -right-3 sm:-top-14 sm:-right-6 balloon-anim pointer-events-auto"
    style="animation-delay: 2s"
  >
    <span
      class="emoji-span text-5xl md:text-6xl cursor-pointer select-none filter drop-shadow-md transition-transform hover:scale-110"
      >🎉</span
    >
  </div>

  <!-- Etiqueta decorativa superior -->
  <div class="flex flex-col items-center gap-1.5 mb-6">
    <span
      class="inline-block bg-emerald-100 text-emerald-700 font-bold px-5 py-2 rounded-full text-xs md:text-sm tracking-wider uppercase shadow-sm border border-emerald-200"
    >
      🎓 Invitación de Honor 🎓
    </span>
    <span class="text-xs font-semibold text-slate-400 uppercase tracking-widest mt-1">
      Verano 2026
    </span>
  </div>

  <!-- Información de los Centros Educativos Coordinadores -->
  <div class="max-w-2xl mx-auto mb-8 px-2">
    <div class="space-y-4">
      <div class="relative py-1">
        <h2 class="text-lg md:text-2xl font-extrabold text-emerald-800 leading-snug">
          Centro Preescolar Indígena<br class="sm:hidden" /> "Coronel Gregorio Mendez"
        </h2>
        <span class="inline-block mt-1 text-xs bg-amber-100 text-amber-800 px-2.5 py-0.5 rounded-full font-mono font-bold border border-amber-200">
          C.C.T. 27DCC0145T
        </span>
      </div>

      <div class="flex items-center justify-center gap-2 text-xs font-bold text-slate-400 uppercase tracking-wider">
        <span class="h-[1px] w-8 bg-slate-200"></span>
        <span>en coordinación con el</span>
        <span class="h-[1px] w-8 bg-slate-200"></span>
      </div>

      <div>
        <h2 class="text-lg md:text-2xl font-extrabold text-emerald-800 leading-snug">
          Centro de Educación Inicial<br class="sm:hidden" /> "La Flor del maiz"
        </h2>
        <p class="text-xs md:text-sm text-emerald-600/80 font-medium mt-1">
          R/a Jolochero 2da. sección, Centro, Tabasco.
        </p>
      </div>
    </div>
  </div>

  <div class="w-24 h-1 bg-gradient-to-r from-transparent via-slate-200 to-transparent mx-auto mb-8"></div>

  <!-- Mensaje de Invitación Formal -->
  <div class="max-w-xl mx-auto mb-6">
    <p class="text-slate-500 text-sm md:text-base leading-relaxed mb-4">
      Tienen el honor de invitar a usted a la ceremonia de
    </p>
    <h1
      class="text-4xl md:text-6xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-emerald-600 via-amber-500 to-pink-500 mb-2 drop-shadow-sm leading-tight"
    >
      Graduación
    </h1>
    <p class="text-emerald-600 font-bold text-lg md:text-xl tracking-wide">
      Generación 2023 - 2026
    </p>
    <p class="text-slate-600 text-sm md:text-base mt-4 font-light leading-relaxed">
      Que se llevará a cabo con gran alegría el día <strong class="text-amber-500 font-bold">09 de Julio</strong>
    </p>
  </div>

  <!-- Polaroid con foto grupal -->
  <FotoPolaroid
    pieFoto="¡Generación 2023 - 2026!"
    detallesFoto="Graduación de Preescolar Indígena & C.E.I. - R/a Jolochero 2da. Secc."
  />

  <!-- Pequeño indicador interactivo para divertirse -->
  <p class="text-xs text-slate-400 italic mt-6">
    <i class="fa-solid fa-wand-magic-sparkles text-amber-400"></i> ¡Toquen los globos de las esquinas superiores para ver volar la magia de la graduación!
  </p>
</div>

<script>
  function playPopSound() {
    try {
      const AudioCtxClass = window.AudioContext || (window as any).webkitAudioContext;
      const audioCtx = new AudioCtxClass();

      // Configurar generador de oscilador
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();

      osc.type = "sine";
      // El tono sube de forma rápida exponencial para emular un brinco juguetón
      osc.frequency.setValueAtTime(150, audioCtx.currentTime);
      osc.frequency.exponentialRampToValueAtTime(
        800,
        audioCtx.currentTime + 0.1,
      );

      gain.gain.setValueAtTime(0.3, audioCtx.currentTime);
      gain.gain.exponentialRampToValueAtTime(
        0.01,
        audioCtx.currentTime + 0.12,
      );

      osc.connect(gain);
      gain.connect(audioCtx.destination);

      osc.start();
      osc.stop(audioCtx.currentTime + 0.15);
    } catch (e) {
      console.log(
        "Audio interactivo en espera de interacción previa del usuario.",
      );
    }
  }

  function popBalloon(element: HTMLElement) {
    playPopSound();

    // Animación inmediata de agrandado y desvanecimiento
    element.style.transform = "scale(1.6) translateY(-20px)";
    element.style.opacity = "0";
    element.style.pointerEvents = "none";

    // Localizar coordenadas del globo para el confeti
    const rect = element.getBoundingClientRect();
    const x = rect.left + rect.width / 2;
    const y = rect.top + rect.height / 2;

    if (typeof (window as any).launchConfettiAt === "function") {
      (window as any).launchConfettiAt(x, y);
    }

    // Reaparece amigablemente tras 6 segundos con otro emoji sorpresa
    setTimeout(() => {
      const elements = ["🎈", "🎉", "🧸", "🌻", "🦖", "🌟", "🍎"];
      const newEmoji = elements[Math.floor(Math.random() * elements.length)];
      const span = element.querySelector('.emoji-span');
      if (span) {
        span.textContent = newEmoji;
      }
      element.style.transform = "scale(1) translateY(0)";
      element.style.opacity = "1";
      element.style.pointerEvents = "auto";
    }, 6000);
  }

  // Asignar listeners a los globos
  const buttons = document.querySelectorAll('.balloon-btn');
  buttons.forEach((button) => {
    button.addEventListener('click', () => {
      popBalloon(button as HTMLElement);
    });
  });
</script>
