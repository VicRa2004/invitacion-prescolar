---
---
<canvas id="confetti-canvas"></canvas>

<script>
  const canvas = document.getElementById("confetti-canvas") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d");
  let confetti: ConfettiParticle[] = [];
  let animationFrameId: number | null = null;

  // Ajustar tamaño del lienzo al tamaño de la pantalla
  function resizeCanvas() {
    if (canvas) {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }
  }
  window.addEventListener("resize", resizeCanvas);
  resizeCanvas();

  class ConfettiParticle {
    x: number;
    y: number;
    size: number;
    color: string;
    speedX: number;
    speedY: number;
    gravity: number;
    rotation: number;
    rotationSpeed: number;
    opacity: number;

    constructor(x: number, y: number) {
      this.x = x;
      this.y = y;
      this.size = Math.random() * 8 + 6;
      // Paleta de colores suaves y campestres
      this.color = [
        "#FFB7B2",
        "#B5E2FA",
        "#E1BEE7",
        "#FFDAC1",
        "#C7CEEA",
        "#E2F0CB",
      ][Math.floor(Math.random() * 6)];
      this.speedX = Math.random() * 6 - 3;
      this.speedY = Math.random() * -7 - 3; // Impulso hacia arriba
      this.gravity = 0.18;
      this.rotation = Math.random() * 360;
      this.rotationSpeed = Math.random() * 8 - 4;
      this.opacity = 1;
    }

    update() {
      this.speedY += this.gravity;
      this.x += this.speedX;
      this.y += this.speedY;
      this.rotation += this.rotationSpeed;
      // Desvanecer progresivamente al descender
      if (this.speedY > 0) {
        this.opacity -= 0.009;
      }
    }

    draw() {
      if (!ctx) return;
      ctx.save();
      ctx.translate(this.x, this.y);
      ctx.rotate((this.rotation * Math.PI) / 180);
      ctx.globalAlpha = this.opacity;
      ctx.fillStyle = this.color;
      // Dibujar pequeños papelitos rectangulares
      ctx.fillRect(-this.size / 2, -this.size / 2, this.size, this.size);
      ctx.restore();
    }
  }

  function animateConfetti() {
    if (!ctx || !canvas) return;
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    for (let i = confetti.length - 1; i >= 0; i--) {
      confetti[i].update();
      confetti[i].draw();

      // Remover partículas que salen del lienzo o pierden visibilidad
      if (confetti[i].y > canvas.height || confetti[i].opacity <= 0) {
        confetti.splice(i, 1);
      }
    }

    if (confetti.length > 0) {
      animationFrameId = requestAnimationFrame(animateConfetti);
    } else {
      if (animationFrameId) {
        cancelAnimationFrame(animationFrameId);
      }
      animationFrameId = null;
    }
  }

  // Detonar partículas en un punto preciso de la pantalla
  function launchConfettiAt(x: number, y: number) {
    for (let i = 0; i < 35; i++) {
      confetti.push(new ConfettiParticle(x, y));
    }
    if (!animationFrameId) {
      animateConfetti();
    }
  }

  // Hacer accesible la función globalmente para otros componentes
  (window as any).launchConfettiAt = launchConfettiAt;

  // Lluvia mágica automática inicial al abrir la invitación
  window.addEventListener("load", () => {
    setTimeout(() => {
      // Pequeño guiño de confeti cayendo desde el cielo central
      launchConfettiAt(window.innerWidth / 2, window.innerHeight / 4);
    }, 1000);
  });
</script>
