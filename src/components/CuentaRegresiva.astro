---
---
<!-- Sección de la Cuenta Regresiva -->
<div class="bg-gradient-to-br from-white/95 to-amber-50/35 backdrop-blur-md rounded-3xl p-6 md:p-8 shadow-xl border-4 border-amber-300 text-center mb-12 relative overflow-visible transform transition-all duration-300 hover:shadow-2xl">
  <!-- Adornos flotantes infantiles -->
  <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-amber-400 text-amber-950 font-bold px-4 py-1 rounded-full text-xs uppercase tracking-widest shadow-sm select-none border-2 border-white">
    ⏳ ¡Falta muy poco!
  </div>
  
  <h3 class="text-xl md:text-2xl font-extrabold text-slate-800 mt-2 mb-6 flex items-center justify-center gap-2">
    <i class="fa-solid fa-hourglass-half text-amber-500 animate-bounce"></i>
    <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 via-purple-500 to-sky-500">Comienza la Cuenta Regresiva</span>
  </h3>
  
  <div id="countdown-timer" class="grid grid-cols-4 gap-3 sm:gap-6 max-w-md mx-auto">
    <!-- Días -->
    <div class="bg-pink-50/70 border-b-8 border-pink-400 p-2 sm:p-4 rounded-2xl shadow-md transition-transform hover:-translate-y-1">
      <span id="countdown-days" class="block text-2xl sm:text-4xl font-extrabold text-pink-600">00</span>
      <span class="text-[10px] sm:text-xs font-extrabold text-pink-500 uppercase tracking-wide">Días</span>
    </div>
    <!-- Horas -->
    <div class="bg-sky-50/70 border-b-8 border-sky-400 p-2 sm:p-4 rounded-2xl shadow-md transition-transform hover:-translate-y-1">
      <span id="countdown-hours" class="block text-2xl sm:text-4xl font-extrabold text-sky-600">00</span>
      <span class="text-[10px] sm:text-xs font-extrabold text-sky-500 uppercase tracking-wide">Horas</span>
    </div>
    <!-- Minutos -->
    <div class="bg-purple-50/70 border-b-8 border-purple-400 p-2 sm:p-4 rounded-2xl shadow-md transition-transform hover:-translate-y-1">
      <span id="countdown-minutes" class="block text-2xl sm:text-4xl font-extrabold text-purple-600">00</span>
      <span class="text-[10px] sm:text-xs font-extrabold text-purple-500 uppercase tracking-wide">Min.</span>
    </div>
    <!-- Segundos -->
    <div class="bg-emerald-50/70 border-b-8 border-emerald-400 p-2 sm:p-4 rounded-2xl shadow-md transition-transform hover:-translate-y-1">
      <span id="countdown-seconds" class="block text-2xl sm:text-4xl font-extrabold text-emerald-600">00</span>
      <span class="text-[10px] sm:text-xs font-extrabold text-emerald-500 uppercase tracking-wide">Seg.</span>
    </div>
  </div>
  
  <!-- Contenedor para cuando el evento ya haya comenzado -->
  <div id="countdown-finished" class="hidden text-center py-4">
    <p class="text-2xl md:text-3xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-emerald-600 via-amber-500 to-pink-500 animate-bounce">
      🎉 ¡Llegó el gran día de la Graduación! 🎓
    </p>
    <p class="text-slate-600 text-sm md:text-base mt-2 font-semibold">
      ¡Acompañemos a nuestros graduados en este día tan especial! 🧸🌾
    </p>
  </div>
</div>

<script>
  // Fecha objetivo del evento: 09 de Julio de 2026 a las 3:30 P.M. (Hora Local de Tabasco, México = UTC-6)
  const targetDate = new Date("2026-07-09T15:30:00-06:00").getTime();
  
  function updateCountdown() {
    const now = new Date().getTime();
    const distance = targetDate - now;
    
    const timerElement = document.getElementById("countdown-timer");
    const finishedElement = document.getElementById("countdown-finished");
    
    if (distance < 0) {
      if (timerElement) timerElement.classList.add("hidden");
      if (finishedElement) finishedElement.classList.remove("hidden");
      return;
    }
    
    const days = Math.floor(distance / (1000 * 60 * 60 * 24));
    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((distance % (1000 * 60)) / 1000);
    
    const daysEl = document.getElementById("countdown-days");
    const hoursEl = document.getElementById("countdown-hours");
    const minsEl = document.getElementById("countdown-minutes");
    const secsEl = document.getElementById("countdown-seconds");
    
    if (daysEl) daysEl.innerText = days.toString().padStart(2, '0');
    if (hoursEl) hoursEl.innerText = hours.toString().padStart(2, '0');
    if (minsEl) minsEl.innerText = minutes.toString().padStart(2, '0');
    if (secsEl) secsEl.innerText = seconds.toString().padStart(2, '0');
  }
  
  // Ejecutar y establecer intervalo
  updateCountdown();
  setInterval(updateCountdown, 1000);
</script>
