---
---
<!-- Sol y Nubes Decorativas en el Fondo -->
<div
  class="absolute top-0 left-0 w-full overflow-hidden h-96 pointer-events-none select-none z-0"
>
  <!-- Sol tierno sobre el paisaje -->
  <div
    class="absolute top-6 right-6 md:right-20 w-24 h-24 bg-yellow-300 rounded-full flex items-center justify-center shadow-md animate-pulse"
  >
    <span class="text-4xl">☀️</span>
    <div
      class="absolute inset-0 border-4 border-dashed border-yellow-400 rounded-full animate-spin"
      style="animation-duration: 40s"
    ></div>
  </div>

  <!-- Nubes flotantes del campo -->
  <div class="absolute top-16 left-12 cloud-slow opacity-60">
    <div class="bg-white w-28 h-10 rounded-full relative shadow-sm">
      <div
        class="bg-white w-14 h-14 rounded-full absolute -top-6 left-4"
      ></div>
      <div
        class="bg-white w-12 h-12 rounded-full absolute -top-4 right-4"
      ></div>
    </div>
  </div>
  <div
    class="absolute top-36 right-1/4 cloud-fast opacity-50 hidden md:block"
  >
    <div class="bg-white w-20 h-8 rounded-full relative shadow-sm">
      <div
        class="bg-white w-10 h-10 rounded-full absolute -top-4 left-3"
      ></div>
      <div
        class="bg-white w-8 h-8 rounded-full absolute -top-3 right-3"
      ></div>
    </div>
  </div>
</div>
